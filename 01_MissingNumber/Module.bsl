&НаКлиенте
Процедура НайтиЧисло(Команда)
// 1. Убираем пробелы и разбиваем строку в список по запятым
	МассивСтрок = СтрРазделить(Объект.СтрокаЧисел, ",", Ложь);
	
	// 2. Создаем "Соответствие" для сверхбыстрого поиска чисел (O(1))
	НайденныеЧисла = Новый Соответствие;
	
	Для Каждого Стр Из МассивСтрок Цикл
		Попытка
			// Очищаем текст от лишнего и преобразуем в Число
			ТекЗначение = Число(СокрЛП(Стр));
			
			// Нас интересуют только положительные целые числа (1, 2, 3...)
			Если ТекЗначение > 0 Тогда
				НайденныеЧисла.Вставить(ТекЗначение, Истина);
			КонецЕсли;
		Исключение
			// Если в строке мусор (буквы), просто пропускаем эту часть
		КонецПопытки;
	КонецЦикла;
	
	// 3. Алгоритм поиска: проверяем числа по порядку начиная с 1
	МинимальноеПоложительное = 1;
	
	Пока Истина Цикл
		// Если текущего числа нет в нашей базе - это и есть ответ
		Если НайденныеЧисла.Получить(МинимальноеПоложительное) = Неопределено Тогда
			Прервать;
		КонецЕсли;
		
		МинимальноеПоложительное = МинимальноеПоложительное + 1;
	КонецЦикла;
	
	// Выводим результат пользователю в виде всплывающего окна
	ПоказатьПредупреждение(, "Результат: " + МинимальноеПоложительное);
	
КонецПроцедуры
