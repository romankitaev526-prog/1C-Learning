&НаКлиенте
Процедура НайтиПрефикс(Команда)
	
	// 1. Разбиваем строку по запятым
	МассивСлов = СтрРазделить(Объект.СтрокаСоСловами, ",", Ложь);
	
	КоличествоСлов = МассивСлов.Количество();
	Если КоличествоСлов = 0 Тогда
		ПоказатьПредупреждение(, "Результат: """"");
		Возврат;
	КонецЕсли;

	// 2. Чистим слова от пробелов
	Для Индекс = 0 По МассивСлов.ВГраница() Цикл
		МассивСлов[Индекс] = СокрЛП(МассивСлов[Индекс]);
	КонецЦикла;

	// 3. Берем первое слово за эталон
	ПервоеСлово = МассивСлов[0];
	ДлинаПервого = СтрДлина(ПервоеСлово);
	Префикс = "";

	// 4. Идем по буквам ПЕРВОГО слова
	Для Позиция = 1 По ДлинаПервого Цикл
		
		СимволДляПроверки = Сред(ПервоеСлово, Позиция, 1);
		
		// Проверяем этот символ во всех остальных словах
		Для Индекс = 1 По МассивСлов.ВГраница() Цикл
			
			ТекущееСлово = МассивСлов[Индекс];
			
			// Если слово кончилось ИЛИ буква в этой позиции другая - ВСЁ, стоп!
			Если (Позиция > СтрДлина(ТекущееСлово)) ИЛИ (Сред(ТекущееСлово, Позиция, 1) <> СимволДляПроверки) Тогда
				// Выходим из всех циклов и выдаем то, что успели накопить
				Перейти ~ВыводРезультата;
			КонецЕсли;
			
		КонецЦикла;
		
		// Если буква есть у всех - добавляем её в наш префикс
		Префикс = Префикс + СимволДляПроверки;
		
	КонецЦикла;

	~ВыводРезультата:
	
	// 5. Формируем красивый итог для ТЗ
	Итог = ?(Префикс = "", """""", Префикс);
	ПоказатьПредупреждение(, "Результат: " + Итог);
	
КонецПроцедуры
